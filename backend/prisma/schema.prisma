// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// 1. This generates types for the Backend
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// 2. This pushes a copy of the types directly into the Frontend!
generator client_frontend {
  provider = "prisma-client-js"
  output   = "../../frontend/node_modules/.prisma/client" // <--- CHANGED @ TO .
}


datasource db {
  provider = "postgresql"
}

// 1. Table for Contact Form Submissions
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?  
  message   String
  isRead    Boolean  @default(false) 
  createdAt DateTime @default(now())
}

// 2. Main Table for Portfolio Projects
model PortfolioProject {
  id              String   @id @default(uuid())
  slug            String   @unique // Used for URLs: /projects/riad-al-maqam
  title           String
  category        String   // e.g., 'Riad', 'Villa', 'Boutique Hotel'
  location        String   // e.g., 'Marrakech Medina'

  // Long-form content for the Case Study Page
  challenge       String?  // The problem the property faced
  solution        String?  // How Promaroc fixed it

  // Media (You can add gallery arrays later if needed)
  heroImage       String?  // Used in both the grid and the top of the case study
  galleryImages   String[] // NEW: The [] tells Prisma it's an array of strings!
  // Primary Metric (Shown on the main /projects grid)
  mainMetricValue String?  // e.g., '+45%'
  mainMetricLabel String?  // e.g., 'Revenue Increase'

  // Third-party Integrations
  widgetId        String?  // ID for Elfsight/Trustindex Booking.com reviews

  // Admin Dashboard Controls
  clientName      String?  
  projectUrl      String?  
  isPublished     Boolean  @default(false) // Allows Admins to save as 'Draft' before publishing

  // Relationships
  metrics         ProjectMetric[] // One-to-Many relation: A project can have multiple bento box metrics

  propertyId      String?   @unique
  property        Property? @relation(fields: [propertyId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 3. Table for Case Study Bento Box Metrics (e.g. 98% Occupancy)
model ProjectMetric {
  id          String   @id @default(uuid())
  value       String   // e.g., '98%'
  label       String   // e.g., 'Peak Occupancy'
  iconName    String   // e.g., 'TrendingUp', 'Globe', 'Star' (Tells the frontend which Lucide icon to use)

  // Relation back to the PortfolioProject
  projectId   String
  project     PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// AUTHENTICATION TABLES (Auth.js)
// ==========================================

enum Role {
  USER     // A standard guest looking to book
  HOST     // A user who has active property listings
  ADMIN    // You
}

enum PropertyType {
  APARTMENT
  VILLA
  RIAD
  BOUTIQUE_HOTEL
  GUEST_HOUSE
  STUDIO
}

enum PropertyStatus {
  PENDING    // Waiting for Admin approval
  APPROVED   // Live on the marketplace
  REJECTED   // Denied by Admin
}

enum BookingStatus {
  PENDING     // Waiting for host approval or payment
  CONFIRMED   // Payment secured, dates locked
  CANCELLED   // Cancelled by host or guest
  COMPLETED   // Stay has finished
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}


// ==========================================
// 3. THE PROPERTY MODEL (Listings)
// ==========================================

model Property {
  id                  String   @id @default(cuid())
  title               String
  description         String   @db.Text
  propertyType        PropertyType @default(APARTMENT)
  
  // Location
  location            String   // e.g., "Marrakech Medina"
  address             String?  // Full physical address
  city                String?
  country             String?  @default("Morocco")
  latitude            Float?   // For Google Maps integration later
  longitude           Float?

  // Details & Specs (Inspired by your PDF)
  pricePerNight       Float
  bedrooms            Int
  bathrooms           Int
  maxGuests           Int
  sizeSqm             Float?   // e.g., 236 sqm
  buildYear           Int?     // e.g., 2021
  
  // Array of strings: ["Pool", "WiFi", "24/7 Security", "Indoor Games"]
  amenities           String[] 

  // Media
  heroImage           String?
  galleryImages       String[]
  videoUrl            String?  // From PDF "Preview Video" section
  
  // Admin & System Flags
  status              PropertyStatus @default(APPROVED) 
  isManagedByPromaroc Boolean        @default(false) // Promaroc "Premium" Badge
  isBookable          Boolean        @default(true)   // Toggle to pause bookings

  // 🔗 Relationships
  ownerId             String
  owner               User           @relation("UserProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  
  bookings            Booking[]
  portfolioProject    PortfolioProject? // Link back to the marketing Case Study

  conversations      Conversation[]
  savedBy SavedProperty[] @relation("PropertySavedBy")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ==========================================
// 4. THE BOOKING ENGINE
// ==========================================

model Booking {
  id              String   @id @default(cuid())
  
  // 🔗 The Property
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  // 🔗 The Guest
  guestId         String
  guest           User     @relation("UserBookings", fields: [guestId], references: [id], onDelete: Cascade)

  // 📅 Dates & Capacity
  checkIn         DateTime
  checkOut        DateTime
  guestsCount     Int

  // 💰 Financials (Snapshot at time of booking)
  // We lock these in case the host changes the price later!
  pricePerNight   Float    
  cleaningFee     Float?   @default(0)
  serviceFee      Float?   @default(0)
  totalPrice      Float
  
  paymentStatus   PaymentStatus @default(UNPAID)

  // 📋 Status & Notes
  status          BookingStatus @default(PENDING)
  specialRequests String?       @db.Text // E.g., "Need a baby crib"

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// 6. MESSAGING SYSTEM
// ==========================================

model Conversation {
  id          String    @id @default(cuid())
  
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  guestId     String
  guest       User      @relation("GuestConversations", fields: [guestId], references: [id], onDelete: Cascade)
  
  hostId      String
  host        User      @relation("HostConversations", fields: [hostId], references: [id], onDelete: Cascade)
  
  messages    Message[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// ==========================================
// 7. SAVED PROPERTIES (WISHLISTS)
// ==========================================

model SavedProperty {
  id         String   @id @default(cuid())
  
  userId     String
  user       User     @relation("UserSavedProperties", fields: [userId], references: [id], onDelete: Cascade)
  
  propertyId String
  property   Property @relation("PropertySavedBy", fields: [propertyId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())

  // A user can only save a specific property once
  @@unique([userId, propertyId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?   // NEW: Hashed password
  phone         String?   // Added Phone
  country       String?   // Added Country
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  properties      Property[] @relation("UserProperties") // Properties they own
  bookings        Booking[]  @relation("UserBookings")   // Trips they have booked
  guestConversations Conversation[] @relation("GuestConversations")
  hostConversations  Conversation[] @relation("HostConversations")
  messagesSent       Message[]
  savedProperties SavedProperty[] @relation("UserSavedProperties")
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}